# Copia a .env y rellena los valores locales.
# El backend carga este archivo desde la raíz del proyecto.

# Google OAuth Web Client ID. El frontend lo lee desde /auth/client-config.
GOOGLE_CLIENT_ID=

# Secreto para firmar la cookie de sesión JWT. Mínimo 32 bytes.
# En producción usa un valor largo y aleatorio.
JWT_SECRET=

# Correos con rol OWNER global separados por coma. Ej: owner@empresa.com
OWNER_EMAILS=

# Postgres para usuarios, organizaciones y membresias.
# En Docker se inyecta automaticamente desde POSTGRES_* si DATABASE_URL queda vacio.
DATABASE_URL=
POSTGRES_DB=oilmine
POSTGRES_USER=oilmine
POSTGRES_PASSWORD=

# Validez del access token en minutos. Default: 60.
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Cookie de sesión. En HTTPS usa SESSION_COOKIE_SECURE=true.
SESSION_COOKIE_NAME=oilmine_session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax

# Tolerancia al validar el ID token de Google.
GOOGLE_ID_TOKEN_CLOCK_SKEW_SECONDS=120

# Atlas. Solo se usa server-side en atlas-service, nunca en el frontend.
GOOGLE_API_KEY=
ATLAS_PORT=8787
ATLAS_MODEL=gemini-3-flash-preview
ATLAS_TOOL_MAX_STEPS=8
ATLAS_MAX_SLICE_ROWS=500

# Copia a .env y rellena (PowerShell: Copy-Item .env.example .env)
# El backend carga automáticamente .env en la raíz del proyecto (python-dotenv).

# Google OAuth — Client ID Web (GIS). El frontend lo obtiene con GET /auth/client-config.
GOOGLE_CLIENT_ID=

# Opcional — segundos de tolerancia de reloj al validar el token (default 120). Sube si ves "Token used too early".
# GOOGLE_ID_TOKEN_CLOCK_SKEW_SECONDS=120

# Secreto para firmar JWT de sesión (en producción usa un valor largo y aleatorio).
JWT_SECRET=

# Opcional — horas de validez del access token (default 24).
# JWT_EXPIRE_HOURS=24
